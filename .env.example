# ──────────────────────────────────────────────────────────────
# 複製成 .env.local（本機）或填進部署平台環境變數。金鑰只放伺服器端，前端拿不到（NEXT_PUBLIC_ 前綴例外）。
# 完全不填 → 專案以「Demo 模式」執行（用 fixtures 假資料，不呼叫外部服務）。
# 分組：【必填核心】【Threads】【短網域】【AI 文案】【選填整合】【通知】【排程】【防封節奏】【廣告】
# ──────────────────────────────────────────────────────────────

# ════════ 【必填核心】不填就是 Demo 模式 ════════
# Supabase（資料庫 + Auth）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 加密主金鑰：加密存進 DB 的各使用者憑證（Threads token／Shopee secret／Gemini 金鑰）。
# 產生：openssl rand -base64 32
# ⚠️ 上線後不要更換：換了舊資料就解不開，所有已綁憑證都要重綁。
APP_ENCRYPTION_KEY=

# owner（管理者）email：只有此帳號是 owner（可用爬蟲＋自己的 Shopee 分潤金鑰），其餘登入者為 member。
# 需與 Supabase Auth 裡的帳號 email 一致。
OWNER_EMAIL=

# 排程觸發保護：呼叫 /api/cron* 時需帶此密鑰當 header，擋外部亂打。產生：openssl rand -hex 32
CRON_SECRET=

# ════════ 【Threads OAuth】一鍵連發文帳號（免手貼 access token）════════
# Meta 開發者後台建立 Threads App 取得；REDIRECT_URI 需與後台「Valid OAuth Redirect URI」完全一致：
#   https://<你的主網域>/api/auth/threads/callback
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_REDIRECT_URI=

# ════════ 【短網域】go2read 中轉導流 ════════
# 自有短連結網域；同時做 middleware host gating（此網域只服務 /r/*，其餘 404）。需含 https://
NEXT_PUBLIC_SHORT_DOMAIN=https://go2read.link

# ════════ 【AI 文案】預設 Gemini（多模態、便宜快速）════════
AI_PROVIDER=gemini
# 全域 Gemini 金鑰：選填。實際生成一律用「各使用者在帳號管理自綁的金鑰」，此值僅後備/特定流程用。
GEMINI_API_KEY=
# 選填，留空＝用程式預設 gemini-2.5-flash-lite（免費額度最高）。
# ⚠️ 不建議設成 gemini-2.5-flash：免費層每日上限低很多，選「使用預設」的人會很快撞額度。
GEMINI_MODEL=
# 若日後改用 Claude 潤飾才需要：
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ════════ 【選填整合】各使用者多在帳號管理自綁；以下為全域後備 ════════
# Apify（爬 Threads 來源帳號）
APIFY_TOKEN=
APIFY_THREADS_ACTOR=igview-owner/threads-scraper-lite

# Shopee 分潤 Open API（簽名已內建）。owner 也可改在帳號管理綁，不一定要放 env。
SHOPEE_AFFILIATE_APP_ID=
SHOPEE_AFFILIATE_SECRET=
SHOPEE_DEFAULT_SUB_ID=threadspo

# Cloudinary（媒體中轉）。CLOUD_NAME/UPLOAD_PRESET 供上傳；API_KEY/SECRET 僅供儀表板顯示用量（選填）。
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=threads_media
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google Safe Browsing：建短連結時掃描來源網址、於中轉頁顯示安全標章。未設＝降級為基本安全檢查。
GOOGLE_SAFE_BROWSING_KEY=

# ════════ 【通知】════════
# Telegram：bot token（運維告警＋遠端審核草稿）。bot 名稱由 token 自動取得，不需另設 bot URL。
TELEGRAM_BOT_TOKEN=
# 全域運維告警（cron 失敗等）要送到的 chat id；個別使用者審核用的 chat id 存在 DB，不走這裡。
TELEGRAM_CHAT_ID=
# Telegram webhook 驗證密鑰：設了 TELEGRAM_BOT_TOKEN 就「必填」（自訂亂數，openssl rand -hex 32）。
# 未設則 /api/telegram/webhook 一律拒收（fail-closed）。設定後須用此值向 Telegram setWebhook(secret_token)。
TELEGRAM_WEBHOOK_SECRET=

# Web Push 瀏覽器推播（選填）：產生 `npx web-push generate-vapid-keys`。公鑰需 NEXT_PUBLIC 前綴供前端訂閱。
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# 每日摘要附「AI 成效歸因分析」（需 owner Gemini 金鑰，多一次 LLM 呼叫）。1/true 開啟，預設關。
DAILY_DIGEST_AI=

# ════════ 【排程】（常駐型主機如 Zeabur 內建排程，預設開啟；serverless 才關掉改用外部 Cron）════════
# 內建排程預設開啟：常駐機一上線就每 N 分自跑總排程發文，零額外設定（分布式鎖防多實例重複發）。
# serverless（Vercel 等不常駐）請設 INTERNAL_SCHEDULER=false 關閉，改用外部 Cron 打 /api/cron/all。
# INTERNAL_SCHEDULER=false
INTERNAL_SCHEDULER_MINUTES=15

# ════════ 【防封節奏】保守預設，可調 ════════
PUBLISH_MIN_GAP_MINUTES=240          # 每帳號每篇最小間隔（分），業界建議 ≥ 4h
PUBLISH_GAP_JITTER_MINUTES=0         # 保底間隔之上的隨機抖動上限（分），防固定節奏
PUBLISH_MAX_PER_DAY=5                # 每帳號每 24h 上限（Threads 硬上限 250）
PUBLISH_BATCH_PER_RUN=1              # 每次 cron 每帳號最多發幾篇
PRODUCT_COOLDOWN_HOURS=0             # 同分潤商品冷卻期（小時），跨帳號防重複狂洗。0 = 關閉
ACCOUNT_WARMUP_DAYS=0                # 新帳號暖機天數：前 N 天每日上限 1→max 線性遞增。0 = 關閉
PUBLISH_ACCOUNT_FAILURE_LIMIT=0      # 單輪同帳號失敗達此數即跳過其餘草稿（壞/被封帳號斷路器）。0 = 關閉
PUBLISH_CIRCUIT_COOLDOWN_MINUTES=0   # 斷路器觸發後跨輪冷卻（分）。0 = 只在單輪內生效
REPLY_DELAY_MIN_MINUTES=0            # 延遲留言（串文 2/2 連結）保底分鐘。0 = 立即
REPLY_DELAY_JITTER_MINUTES=0         # 保底之上的隨機抖動上限（分）
PUBLISH_SLOTS=09:00,12:30,20:00      # 「加入佇列」每日發文時段（Asia/Taipei，HH:MM 逗號分隔）

# ════════ 【廣告】Google AdSense（選填；建議只在公開頁/中轉頁放）════════
# 設了 CLIENT 才載入廣告與插入驗證 meta；CLIENT 為 ca-pub-…，SLOT 為 AdSense 後台核准後的廣告單元 id。
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_SLOT_CONTENT=    # /sponsored 內容頁廣告單元
NEXT_PUBLIC_ADSENSE_SLOT_REDIRECT=   # /r 中轉頁廣告單元
