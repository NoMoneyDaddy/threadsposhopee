# ──────────────────────────────────────────────────────────────
# 複製成 .env.local 後填入。所有金鑰只放在伺服器端，前端永遠拿不到。
# 沒填的話專案會以「Demo 模式」執行（使用 fixtures，不呼叫外部服務）。
# ──────────────────────────────────────────────────────────────

# Supabase（資料庫 + Auth）。留空則使用本機記憶體 / fixture 假資料。
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 加密用主金鑰（用來加密存進 DB 的 Threads token / Shopee secret）
# 產生方式：openssl rand -base64 32
APP_ENCRYPTION_KEY=

# owner（管理者）email：只有此帳號是 owner（可用爬蟲＋你的 Shopee 分潤金鑰）；
# 其他登入者為 member。需與 Supabase Auth 裡的帳號 email 一致。
OWNER_EMAIL=

# ── Threads OAuth（一鍵連發文帳號，免手貼 access token）──────────
# 在 Meta 開發者後台建立 Threads App 取得；redirect uri 需與後台「Valid OAuth Redirect URI」一致：
#   https://<你的網域>/api/auth/threads/callback
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_REDIRECT_URI=

# ── Apify（爬 Threads 來源帳號）─────────────────────────────
APIFY_TOKEN=
APIFY_THREADS_ACTOR=igview-owner/threads-scraper-lite

# ── Shopee 分潤 Open API（簽名已內建，不再需要外部 Zeabur 服務）──
SHOPEE_AFFILIATE_APP_ID=
SHOPEE_AFFILIATE_SECRET=
SHOPEE_DEFAULT_SUB_ID=threadspo

# ── AI 文案（預設 Gemini，便宜快速、支援影片/圖片分析）─────────
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# 若日後要切 Claude 潤飾：
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Cloudinary（媒體中轉）──────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=threads_media

# ── Google AdSense（選用；建議只在公開頁放）──────────────────
# 設了 client 才會載入廣告與插入驗證 meta（google-adsense-account）。
# client 為 ca-pub-…；slot 為 AdSense 後台建立的廣告單元 id（核准後才有）。
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_SLOT_PRICING=

# ── 排程觸發保護（Cron 會帶這個 header 來呼叫 /api/cron 與 /api/cron/publish）──
CRON_SECRET=

# ── 內建排程（選用，常駐型主機如 Zeabur）──────────────────────
# 設 true 讓 app 自己每 N 分跑總排程，免設外部 Cron Job（serverless 如 Vercel 不適用）。
# 分布式鎖確保多實例不重複發文。用內建排程就不必再設外部 cron（兩者擇一）。
INTERNAL_SCHEDULER=false
INTERNAL_SCHEDULER_MINUTES=15

# ── 發文流程防封節奏（保守預設，可調）──────────────────────────
# 爬取與發文是兩條獨立排程：/api/cron（產草稿）、/api/cron/publish（發文）
PUBLISH_MIN_GAP_MINUTES=240   # 每帳號每篇最小間隔（分），業界建議 ≥ 4h
PUBLISH_GAP_JITTER_MINUTES=0  # 保底間隔之上的隨機抖動上限（分），防固定節奏被偵測
PUBLISH_MAX_PER_DAY=5         # 每帳號每 24h 上限（Threads 硬上限為 250）
PUBLISH_BATCH_PER_RUN=1       # 每次 cron 每帳號最多發幾篇
PRODUCT_COOLDOWN_HOURS=0      # 同一分潤商品冷卻期（小時），跨帳號防重複狂洗。0 = 關閉
ACCOUNT_WARMUP_DAYS=0         # 新帳號暖機天數：前 N 天每日上限 1→max 線性遞增，降低新號封禁。0 = 關閉

# 延遲留言（串文 2/2 分潤連結）：主文發出後隔多久才補留言，避免「秒留言」固定行為被偵測
# 0 = 立即（向後相容）。逐則可在發文表單覆寫。實際延遲 = 保底 + 0..抖動（穩定隨機）
REPLY_DELAY_MIN_MINUTES=0     # 留言延遲「保底」分鐘
REPLY_DELAY_JITTER_MINUTES=0  # 保底之上的隨機抖動上限（分）

# 「加入佇列」用的每日發文時段（Asia/Taipei，HH:MM 逗號分隔）
PUBLISH_SLOTS=09:00,12:30,20:00

# ── 通知（可選）───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Telegram 遠端審核 webhook 驗證密鑰：啟用 TELEGRAM_BOT_TOKEN 時「必填」（自訂亂數）。
# 未設則 /api/telegram/webhook 一律拒收（fail-closed）。設定後須用此值向 Telegram setWebhook（secret_token）。
TELEGRAM_WEBHOOK_SECRET=
# 公開 bot 連結（前端按鈕用）：填了帳號頁才會顯示「開啟 bot 並按 /start」按鈕。
# 須對應 TELEGRAM_BOT_TOKEN 的同一隻 bot（否則使用者會 /start 錯 bot）。只接受 https:／tg: 開頭。例：https://t.me/iwantpo_bot
NEXT_PUBLIC_TELEGRAM_BOT_URL=

# Web Push 瀏覽器推播（可選）：產生金鑰 `npx web-push generate-vapid-keys`
# 公鑰需 NEXT_PUBLIC 前綴供前端訂閱；私鑰僅伺服器用。VAPID_SUBJECT 用 mailto: 或網站網址。
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
